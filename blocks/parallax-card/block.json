{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "stanza/parallax-card",
	"title": "Parallax card",
	"category": "theme",
	"icon": "cover-image",
	"description": "Image-backed feed card with a scrim and optional scroll parallax. Use inside a post template.",
	"textdomain": "stanza",
	"usesContext": [ "postId", "postType" ],
	"attributes": {
		"minHeight": {
			"type": "string",
			"default": "480px"
		},
		"dimOpacity": {
			"type": "number",
			"default": 55
		},
		"parallax": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"interactivity": true,
		"spacing": {
			"margin": true
		}
	},
	"render": "file:./render.php",
	"style": "file:./style.css",
	"viewScriptModule": "file:./view.js",
	"editorScript": "file:./index.js"
}
